# MoveScout environment template
#
# Copy this file to `.env` (kept out of git by default) and fill in values.
# For Plesk: you can also set these under Node.js → "Benutzerdefinierte Umgebungsvariablen".

# Required: Postgres connection string
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Crypto / Auth (required in production)
MOVESCOUT_DATA_ENCRYPTION_KEY=
MOVESCOUT_AUTH_TOKEN_SECRET=

# Optional org defaults
MOVESCOUT_DEFAULT_ORG_KEY=org_default

# Bootstrap admin (created on first run if no users exist)
MOVESCOUT_BOOTSTRAP_ADMIN_USERNAME=Admin
MOVESCOUT_BOOTSTRAP_ADMIN_PASSWORD=

# Optional mail fallback (used if integration settings are not set in DB)
MOVESCOUT_SMTP_HOST=
MOVESCOUT_SMTP_PORT=
MOVESCOUT_SMTP_USER=
MOVESCOUT_SMTP_PASS=
MOVESCOUT_MAIL_FROM=

# Optional routing/geocoding overrides
MOVESCOUT_GEOCODING_URL=
MOVESCOUT_ROUTING_URL=
MOVESCOUT_GEOCODING_USER_AGENT=
